# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-prev-build-*/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local generated uploads
/public/uploads/*
!/public/uploads/.gitkeep

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# local runtime data
/data/

# vendored reference code
/vendor/

# project docs (not part of the app)
/docs/*
!/docs/repo-overpass.md

# typescript
*.tsbuildinfo
next-env.d.ts
